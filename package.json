{
  "name": "gregho-pi-extensions",
  "private": true,
  "version": "0.0.0",
  "description": "Personal pi extensions and packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "style:audit": "node tools/extension-style-audit.mjs",
	"test:tools": "node --test tools/*.test.mjs",
	"verify:release": "node tools/release-gates.mjs"
  }
}
