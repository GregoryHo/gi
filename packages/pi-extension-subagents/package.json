{
	"name": "@gregho/pi-extension-subagents",
	"version": "0.1.0",
	"description": "Foreground read-only subagent delegation facade for pi.",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		}
	},
	"keywords": [
		"pi-package",
		"pi-extension",
		"subagents",
		"delegation"
	],
	"files": [
		"src/agents.ts",
		"src/index.ts",
		"src/subagent.ts",
		"README.md",
		"CHANGELOG.md"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
		"typecheck": "tsc --noEmit",
		"pack:dry-run": "npm pack --dry-run"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@gregho/pi-extension-agent-workers": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"typescript": "^5.8.3"
	}
}
