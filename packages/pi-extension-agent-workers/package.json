{
  "name": "@gregho/pi-extension-agent-workers",
  "version": "0.4.0",
  "description": "pi extension package for supervising delegated AI agent workers, including CLI processes and pi SDK child sessions.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
		},
		"./protocol": {
			"import": "./src/protocol/index.ts",
			"types": "./src/protocol/index.ts"
		}
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "agent-workers",
    "worker-supervision",
    "claude-code",
    "codex-cli",
    "pi-sdk"
  ],
  "files": [
    "src/adapters/claude-code.ts",
    "src/adapters/cli-utils.ts",
    "src/adapters/codex-cli.ts",
    "src/adapters/demo.ts",
    "src/adapters/pi-sdk.ts",
    "src/commands/args.ts",
    "src/commands/format.ts",
    "src/commands/index.ts",
    "src/config/index.ts",
    "src/config/profiles.ts",
    "src/core/request-types.ts",
    "src/core/service.ts",
    "src/core/worker-events.ts",
    "src/core/worker-manager.ts",
    "src/core/worker-types.ts",
		"src/protocol/client.ts",
		"src/protocol/index.ts",
		"src/protocol/server.ts",
		"src/protocol/types.ts",
    "src/index.ts",
    "src/state/logs.ts",
    "src/state/run-index.ts",
    "src/state/workspaces.ts",
    "src/tools/index.ts",
    "src/ui/widget.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
