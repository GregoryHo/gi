{
  "name": "@gregho/pi-extension-api-behavior-audit",
  "version": "0.1.1",
  "description": "pi extension package for collecting and auditing baseline versus candidate backend API behavior.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "api-audit",
    "api-behavior",
    "playwright"
  ],
  "files": [
    "examples/account-activity.scenarios.json",
    "schemas/manifest.v1.schema.json",
    "schemas/exchange.v1.schema.json",
    "schemas/comparison-run.v1.schema.json",
    "schemas/scenario-dictionary.v1.schema.json",
    "src/adapters/artifacts.ts",
    "src/adapters/browser-capture.ts",
    "src/adapters/recording-proxy.ts",
    "src/adapters/target-capture.ts",
    "src/adapters/upstream-account-activity.ts",
    "src/commands/args.ts",
    "src/commands/index.ts",
    "src/commands/package-command.ts",
    "src/config/environment-profiles.ts",
    "src/config/index.ts",
    "src/config/proxy-config.ts",
    "src/config/workspace-paths.ts",
    "src/core/comparison-analysis.ts",
    "src/core/discovery.ts",
    "src/core/discovery-types.ts",
    "src/core/package-info.ts",
    "src/core/redaction.ts",
    "src/core/scenario-dictionary.ts",
    "src/core/scenario-suggestion.ts",
    "src/core/scenarios.ts",
    "src/index.ts",
    "src/schemas/artifact-schema.ts",
    "src/schemas/schema-validation.ts",
    "src/tools/executors.ts",
    "src/tools/index.ts",
    "src/tools/target-profile-executors.ts",
    "src/tools/tool-types.ts",
    "src/types.ts",
    "src/ui/dashboard.ts",
    "tools/**/*.py",
    "tools/*.html",
    "tools/*.js",
    "README.md",
    "CHANGELOG.md",
    ".env.example"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
