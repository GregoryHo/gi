{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gregho.local/pi-extension-api-behavior-audit/exchange.v1.schema.json",
  "title": "API behavior audit ApiExchange v1",
  "type": "object",
  "required": ["runId", "layer", "side", "scenarioId", "request", "response", "timing", "provenance"],
  "additionalProperties": true,
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "layer": { "enum": ["browser-visible", "upstream"] },
    "side": { "enum": ["old", "new"] },
    "scenarioId": { "type": "string", "minLength": 1 },
    "targetId": { "type": "string", "minLength": 1 },
    "variant": { "type": "string", "minLength": 1 },
    "request": {
      "type": "object",
      "required": ["method", "url", "headers", "body"],
      "additionalProperties": true,
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "headers": { "type": "object", "additionalProperties": true },
        "body": {}
      }
    },
    "response": {
      "type": "object",
      "required": ["status", "headers", "body"],
      "additionalProperties": true,
      "properties": {
        "status": { "type": "number" },
        "headers": { "type": "object", "additionalProperties": true },
        "body": {}
      }
    },
    "timing": {
      "type": "object",
      "required": ["startedAt", "durationMs"],
      "additionalProperties": true,
      "properties": {
        "startedAt": { "type": "string", "minLength": 1 },
        "durationMs": { "type": "number" }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["source"],
      "additionalProperties": true,
      "properties": {
        "source": { "enum": ["playwright", "recording-proxy"] },
        "pageUrl": { "type": "string" }
      }
    }
  }
}
