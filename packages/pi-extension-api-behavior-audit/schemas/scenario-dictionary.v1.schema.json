{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gregho.local/pi-extension-api-behavior-audit/scenario-dictionary.v1.schema.json",
  "title": "API behavior audit ScenarioDictionary v1",
  "type": "object",
  "required": ["version", "scenarios"],
  "additionalProperties": true,
  "properties": {
    "version": { "const": 1 },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "feature", "description", "type", "page", "browserApiAllowlist", "upstreamApiCandidates"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "feature": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "type": { "enum": ["read-only"] },
          "page": {
            "type": "object",
            "required": ["oldPath", "newPath"],
            "additionalProperties": true,
            "properties": {
              "oldPath": { "type": "string", "minLength": 1 },
              "newPath": { "type": "string", "minLength": 1 }
            }
          },
          "browserApiAllowlist": {
            "type": "object",
            "required": ["old", "new"],
            "additionalProperties": true,
            "properties": {
              "old": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "new": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
            }
          },
          "upstreamApiCandidates": {
            "type": "object",
            "required": ["old", "new"],
            "additionalProperties": true,
            "properties": {
              "old": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "new": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
            }
          },
          "evidence": {
            "type": "object",
            "required": ["comparisons"],
            "additionalProperties": false,
            "properties": {
              "comparisons": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["comparisonRunId", "targets"],
                  "additionalProperties": true,
                  "properties": {
                    "comparisonRunId": { "type": "string", "minLength": 1 },
                    "targets": {
                      "type": "object",
                      "required": ["old", "new"],
                      "additionalProperties": true,
                      "properties": {
                        "old": { "type": "string", "minLength": 1 },
                        "new": { "type": "string", "minLength": 1 }
                      }
                    },
                    "acceptedAt": { "type": "string", "minLength": 1 },
                    "notes": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
