# Self-hosted Jira Server/Data Center config for pi-extension-jira-board.
# Copy values into your shell environment or an ignored local env file.
# Do not commit real credentials.

JIRA_BASE_URL=https://jira.example.com

# Use either username or email, depending on your Jira auth setup.
JIRA_USER=your-username
# JIRA_EMAIL=you@example.com

# Use either token or password, depending on your Jira auth setup.
JIRA_TOKEN=your-token-or-password
# JIRA_PASSWORD=your-password

# Optional defaults used by search, snapshot, and autocomplete.
JIRA_PROJECT=PROJ
JIRA_BOARD_ID=123
