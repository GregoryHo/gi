{
  "name": "@gregho/pi-extension-jira-board",
  "version": "0.2.0",
  "description": "pi extension package for self-hosted Jira board and issue context.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "jira",
    "jira-server",
    "jira-board"
  ],
  "files": [
    "src/board-snapshot.ts",
    "src/config.ts",
    "src/index.ts",
    "src/issue-mapper.ts",
    "src/jira-autocomplete.ts",
    "src/jira-boards.ts",
    "src/jira-browser.ts",
    "src/jira-client.ts",
    "src/jira-clear.ts",
    "src/jira-cockpit.ts",
    "src/jira-command-issue.ts",
    "src/jira-context.ts",
    "src/jira-facet-picker.ts",
    "src/jira-facets.ts",
    "src/jira-filter.ts",
    "src/jira-kanban.ts",
    "src/jira-commands.ts",
    "src/jira-metadata.ts",
    "src/jira-onboarding.ts",
    "src/jira-query.ts",
    "src/jira-sprints.ts",
    "src/jira-tools.ts",
    "src/jira-types.ts",
    "src/jira-users.ts",
    "src/jira-writes.ts",
    "src/local-config.ts",
    "src/planning-prompts.ts",
    "src/secret-store.ts",
    "README.md",
    "CHANGELOG.md",
    ".env.example"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
