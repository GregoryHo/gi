{
  "name": "@gregho/pi-extension-jira-board",
  "version": "0.2.0",
  "description": "pi extension package for self-hosted Jira board and issue context.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "jira",
    "jira-server",
    "jira-board"
  ],
  "files": [
    "src/adapters/board-snapshot.ts",
    "src/adapters/client.ts",
    "src/adapters/kanban.ts",
    "src/adapters/metadata.ts",
    "src/adapters/query.ts",
    "src/adapters/sprints.ts",
    "src/adapters/users.ts",
    "src/commands/boards.ts",
    "src/commands/browser.ts",
    "src/commands/browser/*.ts",
    "src/commands/clear.ts",
    "src/commands/index.ts",
    "src/commands/onboarding.ts",
    "src/commands/runtime.ts",
    "src/commands/writes.ts",
    "src/config/index.ts",
    "src/config/local.ts",
    "src/config/secrets.ts",
    "src/core/command-issue.ts",
    "src/core/facets.ts",
    "src/core/filter.ts",
    "src/core/issue-mapper.ts",
    "src/core/planning-prompts.ts",
    "src/index.ts",
    "src/state/context.ts",
    "src/tools/index.ts",
    "src/types.ts",
    "src/ui/autocomplete.ts",
    "src/ui/cockpit.ts",
    "src/ui/facet-picker.ts",
    "README.md",
    "CHANGELOG.md",
    ".env.example"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
