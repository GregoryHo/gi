  "license": "MIT",
  "author": "GregoryHo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GregoryHo/gi.git",
    "directory": "packages/pi-extension-web-search"
  },
  "bugs": {
    "url": "https://github.com/GregoryHo/gi/issues"
  },
