{
  "name": "@gregho/pi-extension-goal-mode",
  "version": "0.1.0",
  "description": "pi extension package for bounded autonomous goal loops.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "goal-mode",
    "agent-loop",
    "loop-engineering"
  ],
  "files": [
    "src/commands.ts",
    "src/index.ts",
    "src/loop.ts",
    "src/messages.ts",
    "src/persistence.ts",
    "src/safety.ts",
    "src/state.ts",
    "src/tools.ts",
    "src/verification.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --test --experimental-strip-types",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
